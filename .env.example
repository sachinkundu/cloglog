# Database
# Dev uses cloglog_dev (snapshot of prod). Refresh with `make db-refresh-from-prod`.
DATABASE_URL=postgresql+asyncpg://cloglog:cloglog_dev@localhost:5432/cloglog_dev

# Server
HOST=0.0.0.0
PORT=8000

# Review engine (F-36)
# Filesystem root passed to `codex -C` as the legacy single-repo fallback.
# Used only when REVIEW_REPO_ROOTS is unset/empty. When REVIEW_REPO_ROOTS is
# populated, the resolver REFUSES PRs whose repo is not in the registry
# instead of falling back here — see T-350. MUST be set in prod (single-repo
# hosts) to a checkout that tracks `main`, not the prod worktree that only
# advances on `make promote` (see T-255 / dev-prod-separation spec).
#REVIEW_SOURCE_ROOT=/home/sachin/code/cloglog

# Per-repo review root registry (T-350). REQUIRED on multi-repo backends.
# Maps each `owner/repo` the backend should review to its filesystem
# checkout. When non-empty, the resolver consults this map BEFORE the
# legacy REVIEW_SOURCE_ROOT fallback, and REFUSES (returns None) any PR
# whose `repo_full_name` is absent AND whose branch has no registered
# worktree on this host. The engine surfaces the refusal as a one-shot
# `unconfigured_repo` skip comment instead of running codex against the
# wrong repo. Without this set, a multi-repo host re-opens the antisocial
# PR #2 cross-repo leak — codex reviews foreign PRs against
# REVIEW_SOURCE_ROOT (typically cloglog-prod). Set as JSON on one line.
#REVIEW_REPO_ROOTS={"sachinkundu/cloglog":"/home/sachin/code/cloglog-prod","sachinkundu/antisocial":"/home/sachin/code/antisocial"}

# Main agent inbox (T-253)
# Absolute path to the main agent's inbox file. When set, webhook events for
# PRs that have no owning worktree (e.g. close-wave PRs opened directly by
# the main agent) are routed here instead of being silently dropped. Leave
# unset to preserve the pre-T-253 drop-on-no-match behavior.
#MAIN_AGENT_INBOX_PATH=/home/sachin/code/cloglog/.cloglog/inbox

# Two-stage review — opencode stage A (T-248 / F-47)
# Optional per-host tuning knobs for the local opencode reviewer. Defaults
# listed below match src/shared/config.py; override only if needed.
#
# OPENCODE_ENABLED (T-275) — master switch for stage A. Default FALSE because
# the stock reviewer model (gemma4-e4b-32k) rubber-stamps :pass: regardless of
# the diff, so stage A under the default local model produces noise, not
# signal. On a codex + opencode host the flag being off just means "codex-only
# review"; on an OPENCODE-ONLY host (no codex binary on PATH) you MUST set
# OPENCODE_ENABLED=true or the review pipeline is disabled entirely at boot
# (app.py lifespan emits a loud ERROR log naming the three inputs). Flip this
# once T-274's agentic-mode work lands a reviewer model that defends severity.
#OPENCODE_ENABLED=false
#OPENCODE_CMD=opencode
#OPENCODE_MODEL=ollama/gemma4-e4b-32k
#OPENCODE_MAX_TURNS=5
#CODEX_MAX_TURNS=2
#OPENCODE_TURN_TIMEOUT_SECONDS=240

# The opencode reviewer's GitHub App ID and installation ID are hard-coded
# in src/gateway/github_token.py (same pattern as the claude and codex
# bots). The only per-host artifact is the PEM at
# ~/.agent-vm/credentials/opencode-reviewer.pem — see docs/setup-credentials.md.
