# Database
# Dev uses cloglog_dev (snapshot of prod). Refresh with `make db-refresh-from-prod`.
DATABASE_URL=postgresql+asyncpg://cloglog:cloglog_dev@localhost:5432/cloglog_dev

# Server
HOST=0.0.0.0
PORT=8000

# Review engine (F-36)
# Filesystem root passed to `codex -C`. Must point at a git checkout of the
# PR's merge target (usually main). Unset in dev — falls back to Path.cwd().
# MUST be set in prod to a checkout that tracks `main`, not the prod worktree
# that only advances on `make promote` (see T-255 / dev-prod-separation spec).
#REVIEW_SOURCE_ROOT=/home/sachin/code/cloglog
