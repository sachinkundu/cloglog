.superpowers/
.claude/worktrees/
AGENT_PROMPT.md
# T-360: the plugin ships a canonical workflow template — un-ignore it
# so the launch SKILL can copy it into each worktree's per-launch
# AGENT_PROMPT.md (which stays gitignored by the rule above).
!plugins/cloglog/templates/AGENT_PROMPT.md
__pycache__/
*.pyc
.venv/
*.egg-info/
dist/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
.env
CONTRACT.yaml
.cloglog/inbox
.cloglog/db-schema.sql
.cloglog/launch.sh
# T-348: per-host bot identifiers (gh_app_id / gh_app_installation_id) and
# any other operator-specific overrides. Each operator installs the App into
# their own org/repo and gets a distinct Installation ID; tracking these
# would push other clones at the wrong installation.
.cloglog/local.yaml
.cloglog/task-model
.claude/agent-usage.log
test-results/

# Per-worktree shutdown artifacts (T-242) — generated by the SessionEnd hook
# and/or the agent on shutdown. They were accidentally committed once back in
# April 2026 and every new worktree inherited the stale files via
# `git worktree add`. The bootstrap script wipes the dir on create; this
# rule keeps anything written to it out of git going forward.
shutdown-artifacts/

# Playwright E2E
tests/e2e/playwright/node_modules/
tests/e2e/playwright/test-results/
tests/e2e/playwright/playwright-report/
